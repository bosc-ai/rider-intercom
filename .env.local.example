# LiveKit credentials — get a free project at https://cloud.livekit.io
# Copy this file to .env.local and fill in your values.

# Server-only (used to mint access tokens). Never expose these to the client.
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Public WebSocket URL of your LiveKit project (safe to expose).
# Example: wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
